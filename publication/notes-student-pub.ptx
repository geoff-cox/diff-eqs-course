<?xml version="1.0" encoding="UTF-8"?>
<!--
	Publication file for the STUDENT copy of the Guided Lecture Notes.
	Difference from the instructor copy: worksheet exercise solutions are
	HIDDEN here (exercise-worksheet solution="no"). Instructor-only
	<commentary> blocks are additionally gated by the `commentary`
	stringparam, which is set to "no" on this target in project.ptx.
-->
<publication>

	<source>
		<directories external="notes/assets" generated="notes/generated-assets" />
		<!-- "instructor" is NOT listed, so <commentary component="instructor"> is dropped. -->
		<version include="notes" />
	</source>

	<common>
		<chunking level="1" />
		<tableofcontents level="2" />
		<!-- Worksheet solutions are hidden on the student copy. -->
		<exercise-inline statement="yes" hint="yes" answer="no" solution="no" />
		<exercise-divisional statement="yes" hint="yes" answer="no" solution="no" />
		<exercise-worksheet statement="yes" hint="yes" answer="no" solution="no" />
		<exercise-reading statement="yes" hint="yes" answer="no" solution="no" />
		<!-- Style of fill-in-the-blanks -->
		<fillin textstyle="underline" mathstyle="shade" />
	</common>

	<numbering>
		<divisions chapter-start="1" level="2" />
		<blocks level="1" />
		<projects level="1" />
		<equations level="1" />
		<footnotes level="1" />
	</numbering>

	<html>
		<platform host="web"/>
		<search variant="default" />
		<toc focused="yes" preexpanded-levels="4" />
		<navigation logic="tree" upbutton="yes" />
		<calculator model="none" activecode="none" />
	</html>

</publication>
